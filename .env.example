
# ──────────────────────────────────────────────────────────────────
# MADSAG BACKEND — PRODUCTION ENVIRONMENT
# Deploy this to api.madsag.in server as .env
# ──────────────────────────────────────────────────────────────────

# Server
HOST=0.0.0.0
PORT=1337

# ── SECRETS ──
# Generate fresh values with:
# node -e "console.log(require('crypto').randomBytes(16).toString('base64'))"
APP_KEYS=REPLACE_WITH_RANDOM_KEY_1,REPLACE_WITH_RANDOM_KEY_2,REPLACE_WITH_RANDOM_KEY_3,REPLACE_WITH_RANDOM_KEY_4
API_TOKEN_SALT=REPLACE_WITH_RANDOM_SALT
ADMIN_JWT_SECRET=REPLACE_WITH_RANDOM_SECRET
JWT_SECRET=REPLACE_WITH_RANDOM_SECRET
TRANSFER_TOKEN_SALT=REPLACE_WITH_RANDOM_SALT
ENCRYPTION_KEY=REPLACE_WITH_RANDOM_KEY

# ── DATABASE — PostgreSQL (Production) ──
DATABASE_CLIENT=postgres
DATABASE_URL=postgresql://USERNAME:PASSWORD@localhost:5432/madsag_strapi
# OR use individual fields:
DATABASE_HOST=localhost
DATABASE_PORT=5432
DATABASE_NAME=madsag_strapi
DATABASE_USERNAME=strapi
DATABASE_PASSWORD=YOUR_DB_PASSWORD
DATABASE_SSL=false
# Set to true if your host requires SSL (e.g. Supabase, Railway, Render):
# DATABASE_SSL=true
