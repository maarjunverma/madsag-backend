{
  "kind": "collectionType",
  "collectionName": "blog_posts",
  "info": {
    "singularName": "blog-post",
    "pluralName": "blog-posts",
    "displayName": "Blog Post",
    "description": "MADSAG Journal articles and strategic insights"
  },
  "options": {
    "draftAndPublish": true
  },
  "pluginOptions": {},
  "attributes": {
    "title": {
      "type": "string",
      "required": true,
      "maxLength": 255
    },
    "excerpt": {
      "type": "text",
      "required": true
    },
    "content": {
      "type": "text",
      "required": true
    },
    "author": {
      "type": "string",
      "required": true,
      "default": "MADSAG Team"
    },
    "category": {
      "type": "string",
      "required": true,
      "default": "General"
    },
    "readTime": {
      "type": "string",
      "default": "5 min read"
    },
    "image": {
      "type": "media",
      "multiple": false,
      "required": false,
      "allowedTypes": ["images"]
    },
    "slug": {
      "type": "uid",
      "targetField": "title"
    }
  }
}
